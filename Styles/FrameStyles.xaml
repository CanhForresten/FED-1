<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Bilvaerksted.FrameStyles">

        <Style x:Key="CardFrameStyle" TargetType="Frame">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#FFFFFF, Dark=#2A2A2A}"/>
            <Setter Property="BorderColor" Value="{AppThemeBinding Light=#4B3621, Dark=#444444}"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="HasShadow" Value="True"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5,5"/>
        </Style>

        <Style x:Key="CardFrameAccentStyle" TargetType="Frame">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F7F7F7, Dark=#2A2A2A}"/>
            <Setter Property="BorderColor" Value="#00BFA5"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="HasShadow" Value="True"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="5,5"/>
        </Style>

</ResourceDictionary>