<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Bilvaerksted.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:view="clr-namespace:Bilvaerksted.Views"
    xmlns:local="clr-namespace:Bilvaerksted"
    
    
    Shell.FlyoutBehavior="Flyout"
    Shell.NavBarIsVisible="True"
    Title="Bilvaerksted">
    
    

        <Shell.FlyoutFooter>
        <VerticalStackLayout Padding="20" Spacing="10">
            <BoxView HeightRequest="1" Color="LightGray" /> 
            <HorizontalStackLayout Spacing="20" VerticalOptions="Center">
                <Label Text="Mørkt tema" VerticalOptions="Center" />
                <Switch x:Name="ThemeSwitch" 
                        Toggled="OnThemeToggled" 
                        VerticalOptions="Center" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
        </Shell.FlyoutFooter>


        <ShellContent
            Title="Kalender"
            ContentTemplate="{DataTemplate view:KalenderView}" />

        <ShellContent
            Title="Vis faktura"
            ContentTemplate="{DataTemplate view:SeFakturaView}" />

        <ShellContent
            Title="Opret faktura"
            ContentTemplate="{DataTemplate view:OpretFakturaView}" />

        <ShellContent
            Title="Book"
            ContentTemplate="{DataTemplate view:BookView}" />


</Shell>